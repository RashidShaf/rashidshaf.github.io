generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryAction {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
}

// ==================== USERS ====================

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  firstNameAr String?   @map("first_name_ar")
  lastNameAr  String?   @map("last_name_ar")
  phone       String?
  address     String?
  city        String?
  avatar      String?
  role        UserRole  @default(USER)
  isBlocked   Boolean   @default(false) @map("is_blocked")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  reviews       Review[]
  orders        Order[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  readingLists  ReadingList[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==================== CATEGORIES ====================

model Category {
  id            String    @id @default(uuid())
  name          String
  nameAr        String?   @map("name_ar")
  slug          String    @unique
  description   String?
  descriptionAr String?   @map("description_ar")
  image         String?
  parentId      String?   @map("parent_id")
  displayOrder  Int       @default(0) @map("display_order")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  books    Book[]

  @@map("categories")
}

// ==================== BOOKS ====================

model Book {
  id             String     @id @default(uuid())
  title          String
  titleAr        String?    @map("title_ar")
  slug           String     @unique
  author         String
  authorAr       String?    @map("author_ar")
  isbn           String?    @unique
  description    String?    @db.Text
  descriptionAr  String?    @map("description_ar") @db.Text
  price          Decimal    @db.Decimal(10, 2)
  compareAtPrice Decimal?   @map("compare_at_price") @db.Decimal(10, 2)
  coverImage     String?    @map("cover_image")
  images         String[]   @default([])
  publisher      String?
  publisherAr    String?    @map("publisher_ar")
  publishedDate  DateTime?  @map("published_date")
  language       String     @default("en")
  pages          Int?
  weight         Decimal?   @db.Decimal(6, 2)
  dimensions     String?

  // General product fields
  brand          String?
  color          String?
  material       String?
  ageRange       String?    @map("age_range")

  // Inventory
  stock             Int    @default(0)
  lowStockThreshold Int    @default(5) @map("low_stock_threshold")
  sku               String? @unique

  // Metadata
  categoryId    String?    @map("category_id")
  tags          String[]   @default([])
  averageRating Decimal    @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount   Int        @default(0) @map("review_count")
  isFeatured    Boolean    @default(false) @map("is_featured")
  isBestseller  Boolean    @default(false) @map("is_bestseller")
  isNewArrival  Boolean    @default(false) @map("is_new_arrival")
  isTrending    Boolean    @default(false) @map("is_trending")
  isComingSoon  Boolean    @default(false) @map("is_coming_soon")
  isActive      Boolean    @default(true) @map("is_active")
  viewCount     Int        @default(0) @map("view_count")
  salesCount    Int        @default(0) @map("sales_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  category        Category?        @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]
  readingListItems ReadingListItem[]

  @@index([categoryId])
  @@index([author])
  @@index([price])
  @@index([isFeatured])
  @@index([isActive])
  @@index([salesCount])
  @@map("books")
}

// ==================== REVIEWS ====================

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  rating    Int
  title     String?
  comment   String?  @db.Text
  isVerified Boolean @default(false) @map("is_verified")
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
  @@map("reviews")
}

// ==================== CART ====================

model CartItem {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  bookId    String     @map("book_id")
  quantity  Int        @default(1)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("cart_items")
}

// ==================== ORDERS ====================

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  paymentMethod   String      @default("COD") @map("payment_method")

  shippingName    String  @map("shipping_name")
  shippingPhone   String  @map("shipping_phone")
  shippingAddress String  @map("shipping_address")
  shippingCity    String  @map("shipping_city")
  shippingNotes   String? @map("shipping_notes")

  statusHistory     Json?     @map("status_history")
  estimatedDelivery DateTime? @map("estimated_delivery")
  deliveredAt       DateTime? @map("delivered_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancellationReason String?  @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String     @id @default(uuid())
  orderId   String     @map("order_id")
  bookId    String     @map("book_id")
  quantity  Int
  price     Decimal    @db.Decimal(10, 2)
  title     String
  createdAt DateTime   @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])

  @@map("order_items")
}

// ==================== WISHLIST ====================

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("wishlist_items")
}

// ==================== READING LISTS ====================

model ReadingList {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  nameAr      String?  @map("name_ar")
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReadingListItem[]

  @@index([userId])
  @@map("reading_lists")
}

model ReadingListItem {
  id            String   @id @default(uuid())
  readingListId String   @map("reading_list_id")
  bookId        String   @map("book_id")
  displayOrder  Int      @default(0) @map("display_order")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  readingList ReadingList @relation(fields: [readingListId], references: [id], onDelete: Cascade)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([readingListId, bookId])
  @@map("reading_list_items")
}

// ==================== INVENTORY LOG ====================

model InventoryLog {
  id            String          @id @default(uuid())
  bookId        String          @map("book_id")
  action        InventoryAction
  quantity      Int
  previousStock Int             @map("previous_stock")
  newStock      Int             @map("new_stock")
  note          String?
  performedBy   String?         @map("performed_by")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([bookId])
  @@index([action])
  @@map("inventory_logs")
}

// ==================== SETTINGS ====================

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text
  @@map("settings")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'NEW_ORDER', 'LOW_STOCK', 'NEW_REVIEW'
  title     String
  message   String
  metadata  String?  @db.Text // JSON string for extra data
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("notifications")
}
